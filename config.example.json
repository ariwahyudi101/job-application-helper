{
  "ai": {
    "primary_provider": "groq",
    "fallback_provider": "openrouter",
    "primary_model": "openai/gpt-oss-120b",
    "fallback_model": "minimax/minimax-m2.5:free",
    "resume_rewrite_provider": "groq",
    "resume_rewrite_model": "openai/gpt-oss-120b",
    "groq_api_key": "",
    "openrouter_api_key": "",
    "deepseek_api_key": "",
    "request_timeout_seconds": 60,
    "connect_timeout_seconds": 15,
    "max_retries": 1,
    "retry_backoff_seconds": 1.5
  },
  "paths": {
    "default_resume_path": "resumes/default_resume.md",
    "output_dir": "output",
    "prompts_dir": "job_app_helper/prompts",
    "templates_dir": "job_app_helper/templates",
    "browser_profile_dir": "tmp/browser-profile",
    "automation_screenshots_dir": "output/browser-screenshots"
  },
  "storage": {
    "backend": "sqlite",
    "sqlite_db_path": "job_applications.db"
  },
  "search": {
    "enabled": false,
    "search_api_base_url": "",
    "search_api_key": "",
    "max_results": 5
  },
  "optimization": {
    "min_baseline_score": 50,
    "target_apply_score": 70,
    "stretch_score": 90
  },
  "automation": {
    "enabled": true,
    "mode": "semi_auto",
    "headless": false,
    "max_wait_seconds": 20,
    "stop_before_submit": true
  },
  "computer_use": {
    "provider": "gemini",
    "model": "gemini-2.0-flash",
    "api_key": "",
    "max_steps": 12,
    "screenshot_on_each_step": false,
    "timeout_seconds": 45
  },
  "applicant_profile": {
    "full_name": "",
    "email": "",
    "phone": "",
    "location": "",
    "years_of_experience": "",
    "current_salary": "",
    "expected_salary": "",
    "notice_period": "",
    "work_authorization": ""
  }
}
